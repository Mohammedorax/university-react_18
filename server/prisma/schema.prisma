// University platform — initial Prisma schema
// Database: PostgreSQL
// Design notes:
// - All entities use `cuid()` IDs (short, sortable, URL-safe).
// - Soft-delete via `deletedAt` (NULL = active).
// - `createdAt` / `updatedAt` on every mutable entity.
// - Enums are explicit for roles, statuses, and kinds.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth / Users
// ─────────────────────────────────────────────────────────────

enum UserRole {
  admin
  teacher
  student
  staff
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  student Student?
  teacher Teacher?
  staff   Staff?

  auditLogs AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([role])
}

// ─────────────────────────────────────────────────────────────
// Academic Structure
// ─────────────────────────────────────────────────────────────

model Department {
  id       String  @id @default(cuid())
  name     String  @unique
  code     String  @unique
  students Student[]
  teachers Teacher[]
  courses  Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  credits     Int     @default(3)
  maxStudents Int     @default(30)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  enrollments Enrollment[]
  grades      Grade[]
  schedules   ScheduleEntry[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
  @@index([teacherId])
}

// ─────────────────────────────────────────────────────────────
// People
// ─────────────────────────────────────────────────────────────

model Student {
  id          String   @id @default(cuid())
  universityId String  @unique
  phone       String?
  dateOfBirth DateTime?
  gender      String?
  address     String?
  enrollmentYear Int?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  enrollments Enrollment[]
  grades      Grade[]
  attendances Attendance[]
  payments    Payment[]
  discounts   Discount[]
  documents   StudentDocument[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
}

model Teacher {
  id          String  @id @default(cuid())
  employeeId  String  @unique
  phone       String?
  specialty   String?
  hiredAt     DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  courses Course[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([departmentId])
}

model Staff {
  id         String  @id @default(cuid())
  employeeId String  @unique
  position   String
  phone      String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────────────────────────
// Enrollments / Grades / Attendance
// ─────────────────────────────────────────────────────────────

enum EnrollmentStatus {
  active
  dropped
  completed
}

model Enrollment {
  id        String @id @default(cuid())
  studentId String
  courseId  String

  status EnrollmentStatus @default(active)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId])
  @@index([courseId])
}

model Grade {
  id        String  @id @default(cuid())
  studentId String
  courseId  String

  score     Float
  maxScore  Float   @default(100)
  letter    String?
  semester  String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([courseId])
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([studentId, courseId, date])
  @@index([date])
}

// ─────────────────────────────────────────────────────────────
// Finance
// ─────────────────────────────────────────────────────────────

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

model Payment {
  id        String @id @default(cuid())
  studentId String
  amount    Decimal @db.Decimal(12, 2)
  currency  String  @default("SAR")
  status    PaymentStatus @default(pending)
  reference String? @unique
  note      String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
}

model Discount {
  id        String  @id @default(cuid())
  studentId String
  name      String
  percent   Float
  reason    String?
  validFrom DateTime?
  validTo   DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Schedule
// ─────────────────────────────────────────────────────────────

model ScheduleEntry {
  id       String  @id @default(cuid())
  courseId String
  dayOfWeek Int    // 0..6
  startTime String  // "HH:mm"
  endTime   String  // "HH:mm"
  room      String?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ─────────────────────────────────────────────────────────────
// Inventory
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id          String  @id @default(cuid())
  sku         String  @unique
  name        String
  category    String?
  quantity    Int     @default(0)
  minQuantity Int     @default(0)
  unit        String? @default("piece")
  location    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────────────────────────
// Student Documents
// ─────────────────────────────────────────────────────────────

model StudentDocument {
  id        String  @id @default(cuid())
  studentId String
  type      String
  title     String
  url       String
  sizeBytes Int?
  mimeType  String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────
// Notifications / Audit
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String  @id @default(cuid())
  userId    String
  title     String
  body      String?
  type      String  @default("info")
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id        String  @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?

  actor     User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}
