{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "browserslist": [
    "last 2 versions",
    "> 0.5%",
    "not dead"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production BUILD_MODE=prod vite build",
    "build:dev": "cross-env NODE_ENV=development vite build",
    "build:prod": "cross-env NODE_ENV=production BUILD_MODE=prod vite build",
    "lint": "NODE_ENV=development pnpm install --prefer-offline && eslint .",
    "preview": "NODE_ENV=development pnpm install --prefer-offline && vite preview",
    "test": "NODE_ENV=development npx vitest run -c vitest.unit.config.ts",
    "typecheck": "NODE_ENV=development npx tsc --noEmit",
    "test:e2e": "NODE_ENV=development pnpm install --prefer-offline && playwright test",
    "test:storybook": "NODE_ENV=development pnpm install --prefer-offline && vitest run",
    "install-deps": "NODE_ENV=development pnpm install --prefer-offline",
    "clean": "rimraf node_modules && NODE_ENV=development pnpm install",
    "storybook": "NODE_ENV=development storybook dev -p 6006",
    "build-storybook": "NODE_ENV=development storybook build"
  },
