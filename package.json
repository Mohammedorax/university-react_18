{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "browserslist": [
    "last 2 versions",
    "> 0.5%",
    "not dead"
  ],
  "scripts": {
    "dev": "pnpm install --prefer-offline && vite",
    "build": "pnpm install --prefer-offline && tsc -b && vite build",
    "build:prod": "pnpm install --prefer-offline && tsc -b && BUILD_MODE=prod vite build",
    "lint": "pnpm install --prefer-offline && eslint .",
    "preview": "pnpm install --prefer-offline && vite preview",
    "test": "pnpm install --prefer-offline && vitest run -c vitest.unit.config.ts",
    "typecheck": "npx tsc --noEmit",
    "test:e2e": "pnpm install --prefer-offline && playwright test",
    "test:storybook": "pnpm install --prefer-offline && vitest run",
    "install-deps": "pnpm install --prefer-offline",
    "clean": "rimraf node_modules && pnpm install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
