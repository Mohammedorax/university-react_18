# Environment Variables
# ملف البيئة - لا يُرفع إلى Git

# ============================================
# JWT Configuration
# ============================================
VITE_JWT_SECRET=university-production-secret-key-change-this-in-production-2024
VITE_JWT_EXPIRY=24h

# ============================================
# API Configuration
# ============================================
VITE_API_URL=http://localhost:4000
VITE_API_TIMEOUT=30000

# ============================================
# Rate Limiting
# ============================================
VITE_RATE_LIMIT_MAX_ATTEMPTS=5
VITE_RATE_LIMIT_WINDOW=900000
VITE_RATE_LIMIT_LOCKOUT=900000

# ============================================
# Application Settings
# ============================================
VITE_APP_NAME=University Management System
VITE_APP_VERSION=1.0.0
VITE_MAX_FILE_SIZE=10485760

# ============================================
# Feature Flags
# ============================================
VITE_FEATURE_REALTIME_UPDATES=false
VITE_FEATURE_OFFLINE_QUEUE=true
VITE_FEATURE_WEB_SOCKETS=false

# ============================================
# Storage Configuration
# ============================================
VITE_STORAGE_TYPE=indexedDB
VITE_STORAGE_DB_NAME=UniversityDB
VITE_STORAGE_DB_VERSION=1

# ============================================
# Security Settings
# ============================================
VITE_CSP_ENABLED=true
VITE_CSP_SCRIPT_SRC=self unsafe-inline unsafe-eval
VITE_CSP_STYLE_SRC=self unsafe-inline https://fonts.googleapis.com
VITE_CSP_CONNECT_SRC=self http://localhost:4000 ws://localhost:4000
VITE_CSP_IMG_SRC=self data: blob:
VITE_CSP_FONT_SRC=self https://fonts.gstatic.com

# ============================================
# Error Tracking (Production Only)
# ============================================
VITE_SENTRY_DSN=https://xxxxx@xxxx.ingest.sentry.io/xxxxx
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Analytics (Production Only)
# ============================================
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_ANALYTICS_DEBUG=false

# ============================================
# Build Configuration
# ============================================
VITE_BUILD_MODE=development
VITE_SOURCE_MAP=false
VITE_MINIFY=true

# ============================================
# Upload Configuration
# ============================================
VITE_UPLOAD_ALLOWED_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx
VITE_UPLOAD_MAX_SIZE_MB=10

# ============================================
# Password Requirements
# ============================================
VITE_PASSWORD_MIN_LENGTH=8
VITE_PASSWORD_REQUIRE_UPPERCASE=true
VITE_PASSWORD_REQUIRE_LOWERCASE=true
VITE_PASSWORD_REQUIRE_NUMBER=true
VITE_PASSWORD_REQUIRE_SPECIAL=true
